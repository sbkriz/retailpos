# Application Environment
APP_ENV=development

# ============================================
# Mock Service Flags (set to 'false' for real implementation)
# ============================================
USE_MOCK_SCANNER=true
USE_MOCK_PAYMENT=true
USE_MOCK_SECRETS=true
USE_MOCK_PRINTERS=true

# ============================================
# Shopify Configuration
# ============================================
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_URL=
SHOPIFY_SYNC_BATCH_SIZE=50

# ============================================================
# WooCommerce  →  http://localhost:8010
# REST API uses Basic Auth: consumer_key:consumer_secret
# Generate keys at: WP Admin → WooCommerce → Settings → Advanced → REST API
# Until you generate real keys, the values below are placeholders
# that match the seeded admin account.
# ============================================================
WOOCOMMERCE_URL=http://localhost:8010
WOOCOMMERCE_CONSUMER_KEY=ck_retailpos_demo_key_1234567890abcdef
WOOCOMMERCE_CONSUMER_SECRET=cs_retailpos_demo_secret_1234567890ab
WOOCOMMERCE_KEY=ck_retailpos_demo_key_1234567890abcdef
WOOCOMMERCE_SECRET=cs_retailpos_demo_secret_1234567890ab
WOOCOMMERCE_API_VERSION=wc/v3
WOOCOMMERCE_WEBHOOK_URL=

# ============================================
# BigCommerce Configuration
# ============================================
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_CLIENT_ID=
BIGCOMMERCE_ACCESS_TOKEN=
BIGCOMMERCE_API_VERSION=v3
BIGCOMMERCE_WEBHOOK_URL=

# ============================================================
# Magento 2  →  http://localhost:8020
# Uses Bearer token auth. The token below is obtained by calling:
#   POST http://localhost:8020/rest/V1/integration/admin/token
#   Body: { "username": "admin", "password": "Admin1234!" }
# The MAGENTO_ACCESS_TOKEN is populated automatically by the
# MagentoApiClient.fetchAdminToken() method using USERNAME+PASSWORD.
# ============================================================
MAGENTO_STORE_URL=http://localhost:8020
MAGENTO_USERNAME=admin
MAGENTO_PASSWORD=Admin1234!
MAGENTO_ACCESS_TOKEN=
MAGENTO_ADMIN_PATH=admin
MAGENTO_API_VERSION=V1
MAGENTO_SOURCE_CODE=default

# ============================================================
# Sylius  →  http://localhost:8030
# Uses Bearer token (OAuth2). Obtain a token by calling:
#   POST http://localhost:8030/api/v2/shop/authentication-token
#   Body: { "email": "jane.doe@example.com", "password": "password" }
# Or admin token:
#   POST http://localhost:8030/api/v2/admin/authentication-token
#   Body: { "email": "admin@example.com", "password": "admin" }
# ============================================================
SYLIUS_API_URL=http://localhost:8030
SYLIUS_API_KEY=
SYLIUS_API_SECRET=
SYLIUS_ACCESS_TOKEN=

# ============================================
# Wix Configuration
# ============================================
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=
WIX_API_VERSION=v1

# ============================================================
# PrestaShop  →  http://localhost:8040
# Uses Basic Auth: API_KEY as username, empty password.
# Generate a key at: Admin → Advanced Parameters → Webservice → Add new key
# Enable the webservice first: Admin → Advanced Parameters → Webservice → Enable
# ============================================================
PRESTASHOP_STORE_URL=http://localhost:8040
PRESTASHOP_API_KEY=DEMO_API_KEY_REPLACE_AFTER_GENERATING

# ============================================
# Squarespace Commerce Configuration
# ============================================
SQUARESPACE_API_KEY=
SQUARESPACE_SITE_ID=
SQUARESPACE_API_VERSION=1.0

# ============================================
# Payment Configuration
# ============================================
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Square
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=